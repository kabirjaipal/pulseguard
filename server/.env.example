# Database connection URL
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulseguard

# JWT configuration for security
SECRET_KEY=dev_secret_key_pulseguard_change_in_production_1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis connection URL (used for Celery broker and backend)
REDIS_URL=redis://localhost:6379/0

# SMTP configuration for email alerts (Optional: default logs to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@pulseguard.io

# OpenRouter AI Configuration for AI Incident Analysis (Optional: default uses mock AI)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=meta-llama/llama-3-8b-instruct:free
